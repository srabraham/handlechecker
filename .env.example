# Copy to .env and edit. Used by docker-compose.yml.

# The domain this server answers on. DNS must point at this host. Required.
TLS_DOMAIN=handles.example.org

# Contact email registered with Let's Encrypt (expiry warnings). Recommended.
TLS_EMAIL=you@example.org

# Set to true to use the Let's Encrypt staging CA while testing (untrusted
# certs, high rate limits). Leave false/unset for real certificates.
TLS_STAGING=false
